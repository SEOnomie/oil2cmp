{
  "name": "oil2",
  "version": "0.1.0",
  "description": "Lean Consent Management Platform for Performance Marketing",
  "type": "module",
  "main": "dist/oil2.min.js",
  "module": "dist/oil2.es.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "src/stub.js"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && OIL2_FORMAT=es vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src/",
    "typecheck": "tsc --noEmit",
    "size": "vite build && gzip -c dist/oil2.min.js | wc -c"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "happy-dom": "^20.10.6",
    "terser": "^5.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT"
}
